# URL PocketBase server Anda 
# (Gunakan alamat IP lokal komputer Anda jika mengakses via HP, misal: http://192.168.1.15:8090)
EXPO_PUBLIC_PB_URL=http://127.0.0.1:8090

# =========================================================================
# PENTING: JANGAN PERNAH MENYIMPAN API KEY RAHASIA DI SINI (seperti Gemini)
# =========================================================================
# Aplikasi ini menggunakan arsitektur proxy yang aman.
# GEMINI_API_KEY harus dipasang di sisi server (OS environment variables) 
# tempat PocketBase berjalan, BUKAN di file .env frontend ini.
